{
  "name": "dunebuilder",
  "version": "0.1.0",
  "description": "Character build viewer for Dune: Awakening",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:scan": "electron-builder --win portable && node scripts/vt-scan.js"
  },
  "build": {
    "appId": "com.dunebuilder.app",
    "productName": "DuneBuilder",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "items_garment_t1.json",
      "items_garment_t2.json",
      "items_garment_t3.json",
      "items_garment_t4.json",
      "items_garment_t5.json",
      "items_garment_t6.json",
      "items_utility.json",
      "augments_garment.json",
      "augments_generic.json",
      "augments_melee.json",
      "augments_ranged.json",
      "imgs/**/*",
      "dunebuilder_logo_512.png"
    ],
    "win": {
      "target": "portable",
      "icon": "dunebuilder_logo_512.png"
    },
    "portable": {
      "artifactName": "DuneBuilder-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  }
}
